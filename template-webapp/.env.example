# MongoDB connection. Dev default is non-authed local Mongo.
# On Vercel, set this in the project dashboard to a hosted Mongo (e.g. Atlas):
# Settings → Environment Variables → MONGODB_URI
MONGODB_URI=mongodb://localhost:27017

# Database name (optional, defaults to "macrobiotica")
MONGODB_DB=macrobiotica

# Real user-generated-content database (accounts with "Example data" switched
# off read/write here). Optional, defaults to "macrobiotica_ugc".
MONGODB_DB_UGC=macrobiotica_ugc
